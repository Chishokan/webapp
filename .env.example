# PostgreSQL 接続URL（コネクションプーリング経由）。
# Neon の場合は "Pooled connection"、Vercel Postgres の場合は POSTGRES_PRISMA_URL を使う。
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# マイグレーション用の直接接続URL（プーリング非経由）。
# Neon の "Direct connection"、Vercel Postgres の POSTGRES_URL_NON_POOLING を使う。
DIRECT_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# セッション署名用の秘密鍵（必ずランダムな十分長い文字列に変更）
# 生成例: openssl rand -hex 32
AUTH_SECRET="change-me-to-a-long-random-string"

# Anthropic Claude API キー（AI機能 ③④ で使用）
ANTHROPIC_API_KEY=""

# 使用する Claude モデル
ANTHROPIC_MODEL="claude-sonnet-4-6"

# おはよう勉強会の Zoom 参加 URL
NEXT_PUBLIC_ZOOM_URL="https://zoom.us/j/your-meeting-id"

# 各種ログ（AIチャット/出席/リフレクション/AIアドバイス/アカウント操作）を
# Google スプレッドシートに残す場合の GAS WebアプリURL（任意）。
# 設定方法は scripts/sheet-log-gas.gs を参照。未設定ならログ送信しない。
# 後方互換のため CHATLOG_WEBHOOK_URL も引き続き利用可（SHEET_WEBHOOK_URL を優先）。
SHEET_WEBHOOK_URL=""
SHEET_WEBHOOK_TOKEN=""
# 旧設定（そのままでも全ログ送信に使われます）
CHATLOG_WEBHOOK_URL=""
CHATLOG_WEBHOOK_TOKEN=""

# 運営管理画面（/manage）の管理専用ID・パスワード。
# OHAYOU_ADMIN_PASSWORD を設定すると /manage-login からログインできる（未設定なら無効）。
OHAYOU_ADMIN_ID="ohayou-admin"
OHAYOU_ADMIN_PASSWORD=""

# 旧・職員管理(/admin)を一時的に有効化する場合のみ "true"。既定は非表示。
ENABLE_LEGACY_ADMIN=""
