# SQLite (開発用)。本番では PostgreSQL 等の URL に変更してください
DATABASE_URL="file:./dev.db"

# セッション署名用の秘密鍵（必ずランダムな十分長い文字列に変更）
AUTH_SECRET="change-me-to-a-long-random-string"

# Anthropic Claude API キー（AI機能で使用）
ANTHROPIC_API_KEY=""

# 使用する Claude モデル
ANTHROPIC_MODEL="claude-sonnet-4-6"

# おはよう勉強会の Zoom 参加 URL
NEXT_PUBLIC_ZOOM_URL="https://zoom.us/j/your-meeting-id"
