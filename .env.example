# PostgreSQL 接続URL（コネクションプーリング経由）。
# Neon の場合は "Pooled connection"、Vercel Postgres の場合は POSTGRES_PRISMA_URL を使う。
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# マイグレーション用の直接接続URL（プーリング非経由）。
# Neon の "Direct connection"、Vercel Postgres の POSTGRES_URL_NON_POOLING を使う。
DIRECT_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# セッション署名用の秘密鍵（必ずランダムな十分長い文字列に変更）
# 生成例: openssl rand -hex 32
AUTH_SECRET="change-me-to-a-long-random-string"

# Anthropic Claude API キー（AI機能 ③④ で使用）
ANTHROPIC_API_KEY=""

# 使用する Claude モデル
ANTHROPIC_MODEL="claude-sonnet-4-6"

# おはよう勉強会の Zoom 参加 URL
NEXT_PUBLIC_ZOOM_URL="https://zoom.us/j/your-meeting-id"

# AIチャットのログを Google スプレッドシートに残す場合の GAS WebアプリURL（任意）。
# 設定方法は scripts/chatlog-gas.gs を参照。未設定ならログ送信しない。
CHATLOG_WEBHOOK_URL=""
# 上記 GAS 側 SHARED_TOKEN と一致させる共有トークン（任意）。
CHATLOG_WEBHOOK_TOKEN=""
